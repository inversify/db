{
  "author": "Roberto Pintos López",
  "bugs": {
    "url": "https://github.com/inversify/db/issues"
  },
  "description": "InversifyJs Prisma package",
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@prisma/config": "7.8.0",
    "@prisma/driver-adapter-utils": "7.8.0",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "prisma": "7.8.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "homepage": "https://inversify.io/db/",
  "keywords": [
    "prisma",
    "inversify",
    "node",
    "typescript"
  ],
  "devEngines": {
    "node": "^24.10.0",
    "pnpm": "^11.4.0"
  },
  "license": "MIT",
  "module": "lib/esm/index.js",
  "exports": {
    ".": "./lib/esm/index.js"
  },
  "name": "@inversifyjs/prisma",
  "peerDependencies": {
    "inversify": "^8.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inversify/db.git"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf lib",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean",
    "test": "vitest run",
    "test:db:generate": "prisma generate --config=./src/sqlite/prisma.config.ts",
    "test:db:migration:generate": "prisma migrate dev --name init --create-only --config=./src/sqlite/prisma.config.ts",
    "test:integration": "pnpm run test --project Integration",
    "test:coverage": "pnpm run test:unit --coverage",
    "test:uncommitted": "pnpm run test --changed=HEAD",
    "test:unit": "pnpm run test --project Unit"
  },
  "type": "module",
  "version": "0.0.0"
}
