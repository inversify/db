{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": ["dist/**", "lib/**"]
    },
    "@inversifyjs/prisma#build": {
      "dependsOn": ["^build", "test:db:generate"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": ["dist/**", "lib/**"]
    },
    "@inversifyjs/prisma#test:db:generate": {
      "inputs": ["src/sqlite/prisma.config.ts", "src/sqlite/schema.prisma"],
      "outputs": ["src/sqlite/generated/**"]
    },
    "format": {
      "inputs": ["src/**/*.{cts,mts,ts}", "prettier.config.{cjs,mjs,js,json}"],
      "outputs": ["src/**/*.{cts,mts,ts}"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts}", "eslint.config.{cjs,mjs,js,json}"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": ["coverage/**"]
    },
    "test:uncommitted": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{cts,mts,ts,tsx}"],
      "outputs": []
    }
  },
  "ui": "tui"
}
